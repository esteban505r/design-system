{
  "name": "@estebanruano/design-tokens-belcorp",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.4",
  "description": "SomosBelcorp design system tokens — single source of truth for Android and (future) iOS. On this branch tokens/ is the SSOT (no Figma/markdown parse step).",
  "type": "module",
  "files": [
    "dist/web",
    "dist/json",
    "dist/figma"
  ],
  "exports": {
    ".": "./dist/web/tokens.js",
    "./css": "./dist/web/tokens.css",
    "./json": "./dist/json/tokens.json"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/esteban505r/design-system.git"
  },
  "homepage": "https://github.com/esteban505r/design-system#readme",
  "bugs": {
    "url": "https://github.com/esteban505r/design-system/issues"
  },
  "engines": {
    "node": ">=18.12.0"
  },
  "keywords": [
    "design-tokens",
    "design-system",
    "style-dictionary"
  ],
  "scripts": {
    "build": "node sd.config.mjs",
    "sync": "node sd.config.mjs",
    "figma:export": "node tokens-to-figma.mjs --out dist/figma/tokens.json",
    "version:set": "node set-release-version.mjs",
    "clean": "rm -rf dist/"
  },
  "author": "",
  "license": "UNLICENSED",
  "devDependencies": {
    "style-dictionary": "^5.4.0"
  }
}
