{
  "font": {
    "size": {
      "h1": {
        "$value": "28px",
        "$type": "dimension",
        "$extensions": {
          "weight": 700,
          "lineHeight": 1.2,
          "letterSpacing": "-0.01em"
        }
      },
      "h2": {
        "$value": "24px",
        "$type": "dimension",
        "$extensions": {
          "weight": 700,
          "lineHeight": 1.25,
          "letterSpacing": "-0.005em"
        }
      },
      "h3": {
        "$value": "20px",
        "$type": "dimension",
        "$extensions": {
          "weight": 700,
          "lineHeight": 1.3
        }
      },
      "h4": {
        "$value": "18px",
        "$type": "dimension",
        "$extensions": {
          "weight": 700,
          "lineHeight": 1.35
        }
      },
      "h5": {
        "$value": "16px",
        "$type": "dimension",
        "$extensions": {
          "weight": 700,
          "lineHeight": 1.4
        }
      },
      "h6": {
        "$value": "14px",
        "$type": "dimension",
        "$extensions": {
          "weight": 700,
          "lineHeight": 1.4
        }
      },
      "body": {
        "$value": "16px",
        "$type": "dimension",
        "$extensions": {
          "weight": 400,
          "lineHeight": 1.5
        }
      },
      "body-sm": {
        "$value": "14px",
        "$type": "dimension",
        "$extensions": {
          "weight": 400,
          "lineHeight": 1.5
        }
      },
      "caption": {
        "$value": "12px",
        "$type": "dimension",
        "$extensions": {
          "weight": 400,
          "lineHeight": 1.4
        }
      },
      "button": {
        "$value": "16px",
        "$type": "dimension",
        "$extensions": {
          "weight": 600,
          "lineHeight": 1
        }
      },
      "mono": {
        "$value": "14px",
        "$type": "dimension",
        "$extensions": {
          "weight": 400,
          "lineHeight": 1.5,
          "family": "mono"
        }
