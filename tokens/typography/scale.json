{
  "font": {
    "family": {
      "display": { "$value": "Montserrat, sans-serif", "$type": "fontFamily" },
      "body":    { "$value": "Montserrat, sans-serif", "$type": "fontFamily" },
      "mono":    { "$value": "JetBrains Mono, monospace", "$type": "fontFamily" }
    },
    "weight": {
      "regular":  { "$value": 400, "$type": "fontWeight" },
      "medium":   { "$value": 500, "$type": "fontWeight" },
      "semibold": { "$value": 600, "$type": "fontWeight" },
      "bold":     { "$value": 700, "$type": "fontWeight" }
    },
    "size": {
      "xs":   { "$value": "0.75rem",  "$type": "dimension", "$description": "12px — Captions" },
      "sm":   { "$value": "0.875rem", "$type": "dimension", "$description": "14px — Secondary UI text" },
      "base": { "$value": "1rem",     "$type": "dimension", "$description": "16px — Body copy" },
      "lg":   { "$value": "1.25rem",  "$type": "dimension", "$description": "20px — Subheadings" },
      "xl":   { "$value": "1.5rem",   "$type": "dimension", "$description": "24px — Section headings" },
      "2xl":  { "$value": "1.875rem", "$type": "dimension", "$description": "30px — Page headings" },
      "3xl":  { "$value": "2.25rem",  "$type": "dimension", "$description": "36px — Hero" },
      "4xl":  { "$value": "3rem",     "$type": "dimension", "$description": "48px — Large display" }
    },
    "lineHeight": {
      "tight":   { "$value": "1.2",  "$type": "number", "$description": "Headings 3xl-4xl" },
      "snug":    { "$value": "1.3",  "$type": "number", "$description": "Headings xl-2xl" },
      "normal":  { "$value": "1.5",  "$type": "number", "$description": "Body text" }
    }
  }
}
